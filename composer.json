{
    "name": "nih/container",
    "type": "library",
    "license": "MIT",
    "description": "NIH container",
    "keywords": [
        "di",
        "dependency",
        "injection",
        "container",
        "injector",
        "autowiring",
        "psr-11"
    ],
    "support": {
        "issues": "https://github.com/nih-soft/container/issues?state=open",
        "source": "https://github.com/nih-soft/container"
    },
    "require": {
        "php": "^8.5",
        "psr/container": "^2.0",
        "yiisoft/injector": "^1.2.0"
    },
    "provide": {
        "psr/container-implementation": "2.0.0"
    },
    "autoload": {
        "psr-4": {
            "NIH\\Container\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NIH\\Container\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit --testdox --no-coverage"
    },
    "scripts-descriptions": {
        "test": "Run all tests"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
